{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "STM32: Build Project",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${command:cmake.buildDirectory}",
                "-j4"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "STM32: Build Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build/Release",
                "--config",
                "Release",
                "-j4"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "dependsOn": "STM32: Configure Release"
        },
    ]
}