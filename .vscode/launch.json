{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32 (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "executable": "${workspaceFolder}/build/debug/ControlSystems_Canards.elf", // Dynamic path
            "cwd": "${workspaceFolder}",
            "armToolchainPath": "C:/ST/STM32CubeCLT_1.17.0/GNU-tools-for-STM32/bin", // Add this!
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "preLaunchTask": "CMake: build", // Change this to the standard CMake build task
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
        },
        {
            "name": "Release (OpenOCD)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Release/ControlSystems_Canards.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "device": "STM32F446RE",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "svdFile": "${workspaceFolder}/.vscode/STM32F446.svd",
            "preLaunchTask": "STM32: Build Release",
            "showDevDebugOutput": "none"
        },
    ]
}