{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32 (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "stlink",
            "executable": "${workspaceFolder}/build/debug/ControlSystems_Canards.elf", // Dynamic path
            "cwd": "${workspaceFolder}",
            "armToolchainPath": "C:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin", // Add this!
            "preLaunchTask": "CMake: build", // Change this to the standard CMake build task
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
        }
    ]
}
