# --- Build Artifacts ---
# Ignore the build directory where CMake generates files and binaries
/[Bb]uild/
/bin/
/obj/
*.elf
*.bin
*.hex
*.map
*.lst

# --- CMake Artifacts ---
# Ignore CMake local settings and cache
CMakeCache.txt
CMakeFiles/
CMakeSettings.json
cmake-build-*/
install/
_deps/

# --- VS Code Metadata ---
# Keep launch.json and tasks.json usually, but ignore local workspace state
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
*.code-workspace
.settings

.vscode/launch.json
# --- STM32CubeMX / IDE Specifics ---
# Ignore the log files and temporary backup files
*.log
*.bak
.mxproject
# Only ignore the ioc backup, keep the .ioc file itself
*.ioc.bak

# --- Compiler / Toolchain ---
# Ignore dependency files generated by the compiler
*.d
*.o
*.su

# --- Windows System Files ---
# Ignore standard Windows hidden files
Thumbs.db
desktop.ini

Core/Logs
